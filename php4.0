<?php
$students = [
    "นายบุณยกร เฉลิมพรวิทิต",
    "นายธนวินท์ ปัถวี",
    "นายปภังกร ลาภาศุภวัฒน์",
    "นายพรพิพัฒน์ ตั้งวิโรจน์กุล",
    "นายภูมิฉัตร ปานทุ่ง",
    "นายไวภพ เพ็ญพันธ์นาค",
    "นายไอศูรย์ อนุศักดิ์ชัยกุล",
    "นายวรท วงศ์คงสวัสดิ์",
    "นายบึงพิพัฒน์ บึงไกร",
    "นายพัทธนันท์ ประยูร",
    "นายรุจิภาส แสงอ่อง",
