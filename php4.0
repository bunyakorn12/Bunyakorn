    "นางสาวณัฐวิภา วงศ์ทองเครือ",
    "นางสาวธิชานัน พลจอหอ",
    "นางสาวนันทิชา มานํ้าเที่ยง",
    "นางสาวอิษฎาอร โชคมงคลเสถียร",
    "นางสาวพิมพ์มาดา เที่ยงสั้น",
    "นางสาวสุวภัทร ปิงเมือง"
];

$total_students = count($students); 

echo "<h2>=== รายงานรายชื่อนักเรียน ห้อง 6/8 ===</h2>";


echo "<h3>1. แสดงผลด้วยคำสั่ง foreach loop</h3>";
$order_foreach = 1; 
foreach ($students as $name) {
    echo "ลำดับที่ " . $order_foreach . " : " . $name . "<br>";
    $order_foreach++;
}

echo "<hr>"; 


echo "<h3>2. แสดงผลด้วยคำสั่ง for loop</h3>";
for ($i = 0; $i < $total_students; $i++) {
    $order_for = $i + 1;
    echo "ลำดับที่ " . $order_for . " : " . $students[$i] . "<br>";
}

echo "<hr>";


echo "<h3>3. แสดงผลด้วยคำสั่ง while loop</h3>";
$w = 0;
while ($w < $total_students) {
    $order_while = $w + 1;
    echo "ลำดับที่ " . $order_while . " : " . $students[$w] . "<br>";
    $w++;
}
